{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "bg_primary":        "#0E0D0B",
    "bg_secondary":      "#090807",
    "bg_highlight":      "#1A1710",
    "border":            "#252018",

    "fg_primary":        "#C8BCA8",
    "fg_dimmed":         "#7A7060",
    "fg_muted":          "#4A4438",
    "fg_gutter":         "#2E2820",

    "tallow":            "#E8B050",
    "ember":             "#D45A20",
    "sienna":            "#A03A18",
    "straw":             "#A07838",
    "slate":             "#7A8EA8",
    "mountain":          "#4A5868",
    "mauve":             "#8A7888",
    "moonlight":         "#9AAEC0",
    "prairie":           "#6A7848",
    "red":               "#C03828",

    "ansi_black":        "#0E0D0B",
    "ansi_red":          "#C03828",
    "ansi_green":        "#6A7848",
    "ansi_yellow":       "#A07838",
    "ansi_blue":         "#4A5868",
    "ansi_magenta":      "#8A7888",
    "ansi_cyan":         "#7A8EA8",
    "ansi_white":        "#C8BCA8",
    "ansi_bright_black": "#2E2820",
    "ansi_bright_red":   "#D84830",
    "ansi_bright_green": "#8A9860",
    "ansi_bright_yellow":"#C89848",
    "ansi_bright_blue":  "#6A7888",
    "ansi_bright_magenta":"#AA98A8",
    "ansi_bright_cyan":  "#9AAEC0",
    "ansi_bright_white": "#E0D8C8"
  },

  "theme": {
    "primary":           { "dark": "tallow",       "light": "tallow" },
    "secondary":         { "dark": "slate",        "light": "slate" },
    "accent":            { "dark": "mauve",        "light": "mauve" },
    "error":             { "dark": "red",          "light": "red" },
    "warning":           { "dark": "ember",        "light": "ember" },
    "success":           { "dark": "straw",        "light": "straw" },
    "info":              { "dark": "slate",        "light": "slate" },
    "text":              { "dark": "fg_primary",   "light": "fg_primary" },
    "textMuted":         { "dark": "fg_muted",     "light": "fg_muted" },
    "background":        { "dark": "none",         "light": "none" },
    "backgroundPanel":   { "dark": "none",         "light": "none" },
    "backgroundElement": { "dark": "bg_highlight", "light": "bg_highlight" },
    "border":            { "dark": "border",       "light": "border" },
    "borderActive":      { "dark": "tallow",       "light": "tallow" },
    "borderSubtle":      { "dark": "border",       "light": "border" },

    "diffAdded":               { "dark": "straw",        "light": "straw" },
    "diffRemoved":             { "dark": "red",          "light": "red" },
    "diffContext":             { "dark": "fg_muted",     "light": "fg_muted" },
    "diffHunkHeader":          { "dark": "fg_muted",     "light": "fg_muted" },
    "diffHighlightAdded":      { "dark": "straw",        "light": "straw" },
    "diffHighlightRemoved":    { "dark": "red",          "light": "red" },
    "diffAddedBg":             { "dark": "#1A1710",      "light": "#1A1710" },
    "diffRemovedBg":           { "dark": "#1A1710",      "light": "#1A1710" },
    "diffContextBg":           { "dark": "bg_secondary", "light": "bg_secondary" },
    "diffLineNumber":          { "dark": "fg_gutter",    "light": "fg_gutter" },
    "diffAddedLineNumberBg":   { "dark": "#1A1710",      "light": "#1A1710" },
    "diffRemovedLineNumberBg": { "dark": "#1A1710",      "light": "#1A1710" },

    "markdownText":            { "dark": "fg_primary",   "light": "fg_primary" },
    "markdownHeading":         { "dark": "ember",        "light": "ember" },
    "markdownLink":            { "dark": "tallow",       "light": "tallow" },
    "markdownLinkText":        { "dark": "slate",        "light": "slate" },
    "markdownCode":            { "dark": "straw",        "light": "straw" },
    "markdownBlockQuote":      { "dark": "fg_muted",     "light": "fg_muted" },
    "markdownEmph":            { "dark": "mauve",        "light": "mauve" },
    "markdownStrong":          { "dark": "ember",        "light": "ember" },
    "markdownHorizontalRule":  { "dark": "border",       "light": "border" },
    "markdownListItem":        { "dark": "tallow",       "light": "tallow" },
    "markdownListEnumeration": { "dark": "slate",        "light": "slate" },
    "markdownImage":           { "dark": "tallow",       "light": "tallow" },
    "markdownImageText":       { "dark": "slate",        "light": "slate" },
    "markdownCodeBlock":       { "dark": "fg_primary",   "light": "fg_primary" },

    "syntaxComment":           { "dark": "fg_muted",     "light": "fg_muted" },
    "syntaxKeyword":           { "dark": "ember",        "light": "ember" },
    "syntaxFunction":          { "dark": "tallow",       "light": "tallow" },
    "syntaxVariable":          { "dark": "fg_primary",   "light": "fg_primary" },
    "syntaxString":            { "dark": "straw",        "light": "straw" },
    "syntaxNumber":            { "dark": "straw",        "light": "straw" },
    "syntaxType":              { "dark": "slate",        "light": "slate" },
    "syntaxOperator":          { "dark": "fg_dimmed",    "light": "fg_dimmed" },
    "syntaxPunctuation":       { "dark": "fg_dimmed",    "light": "fg_dimmed" }
  }
}
