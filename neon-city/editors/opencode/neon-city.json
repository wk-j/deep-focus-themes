{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "bg_primary":         "#0D0221",
    "bg_secondary":       "#07010F",
    "bg_highlight":       "#1A0A3E",
    "border":             "#2A1454",

    "fg_primary":         "#E0D4FF",
    "fg_dimmed":          "#8B7BAE",
    "fg_muted":           "#5C4A82",
    "fg_gutter":          "#3D2E5C",

    "magenta":            "#FF2CF1",
    "plasma":             "#39FF14",
    "cyber":              "#00D4FF",
    "hot_pink":           "#FF69B4",
    "white":              "#FFFFFF",
    "cyan":               "#00FFFF",
    "orange":             "#FF6B2B",
    "blue":               "#448AFF",
    "yellow":             "#FFE744",
    "red":                "#FF1744",
    "twilight":           "#6B5B95",

    "ansi_black":         "#0D0221",
    "ansi_red":           "#FF1744",
    "ansi_green":         "#39FF14",
    "ansi_yellow":        "#FFE744",
    "ansi_blue":          "#448AFF",
    "ansi_magenta":       "#FF2CF1",
    "ansi_cyan":          "#00D4FF",
    "ansi_white":         "#E0D4FF",
    "ansi_bright_black":  "#5C4A82",
    "ansi_bright_red":    "#FF5370",
    "ansi_bright_green":  "#69FF54",
    "ansi_bright_yellow": "#FFF176",
    "ansi_bright_blue":   "#82B1FF",
    "ansi_bright_magenta":"#FF6FF8",
    "ansi_bright_cyan":   "#4DE8FF",
    "ansi_bright_white":  "#FFFFFF"
  },

  "theme": {
    "primary":           { "dark": "cyan",        "light": "cyan" },
    "secondary":         { "dark": "cyber",       "light": "cyber" },
    "accent":            { "dark": "yellow",      "light": "yellow" },
    "error":             { "dark": "red",         "light": "red" },
    "warning":           { "dark": "orange",      "light": "orange" },
    "success":           { "dark": "plasma",      "light": "plasma" },
    "info":              { "dark": "cyber",       "light": "cyber" },
    "text":              { "dark": "fg_primary",  "light": "fg_primary" },
    "textMuted":         { "dark": "fg_muted",    "light": "fg_muted" },
    "background":        { "dark": "none",          "light": "none" },
    "backgroundPanel":   { "dark": "bg_primary",   "light": "bg_primary" },
    "backgroundElement": { "dark": "bg_highlight",  "light": "bg_highlight" },
    "border":            { "dark": "border",      "light": "border" },
    "borderActive":      { "dark": "cyan",        "light": "cyan" },
    "borderSubtle":      { "dark": "border",      "light": "border" },

    "diffAdded":               { "dark": "plasma",      "light": "plasma" },
    "diffRemoved":             { "dark": "red",         "light": "red" },
    "diffContext":             { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHunkHeader":          { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHighlightAdded":      { "dark": "plasma",      "light": "plasma" },
    "diffHighlightRemoved":    { "dark": "red",         "light": "red" },
    "diffAddedBg":             { "dark": "#1A0A3E",     "light": "#1A0A3E" },
    "diffRemovedBg":           { "dark": "#1A0A3E",     "light": "#1A0A3E" },
    "diffContextBg":           { "dark": "bg_secondary","light": "bg_secondary" },
    "diffLineNumber":          { "dark": "fg_gutter",   "light": "fg_gutter" },
    "diffAddedLineNumberBg":   { "dark": "#1A0A3E",     "light": "#1A0A3E" },
    "diffRemovedLineNumberBg": { "dark": "#1A0A3E",     "light": "#1A0A3E" },

    "markdownText":            { "dark": "fg_primary",  "light": "fg_primary" },
    "markdownHeading":         { "dark": "white",       "light": "white" },
    "markdownLink":            { "dark": "cyan",        "light": "cyan" },
    "markdownLinkText":        { "dark": "cyber",       "light": "cyber" },
    "markdownCode":            { "dark": "plasma",      "light": "plasma" },
    "markdownBlockQuote":      { "dark": "fg_muted",    "light": "fg_muted" },
    "markdownEmph":            { "dark": "yellow",      "light": "yellow" },
    "markdownStrong":          { "dark": "white",       "light": "white" },
    "markdownHorizontalRule":  { "dark": "border",      "light": "border" },
    "markdownListItem":        { "dark": "magenta",     "light": "magenta" },
    "markdownListEnumeration": { "dark": "cyber",       "light": "cyber" },
    "markdownImage":           { "dark": "cyan",        "light": "cyan" },
    "markdownImageText":       { "dark": "cyber",       "light": "cyber" },
    "markdownCodeBlock":       { "dark": "fg_primary",  "light": "fg_primary" },

    "syntaxComment":           { "dark": "twilight",    "light": "twilight" },
    "syntaxKeyword":           { "dark": "white",       "light": "white" },
    "syntaxFunction":          { "dark": "magenta",     "light": "magenta" },
    "syntaxVariable":          { "dark": "fg_primary",  "light": "fg_primary" },
    "syntaxString":            { "dark": "plasma",      "light": "plasma" },
    "syntaxNumber":            { "dark": "orange",      "light": "orange" },
    "syntaxType":              { "dark": "cyber",       "light": "cyber" },
    "syntaxOperator":          { "dark": "fg_dimmed",   "light": "fg_dimmed" },
    "syntaxPunctuation":       { "dark": "fg_dimmed",   "light": "fg_dimmed" }
  }
}
