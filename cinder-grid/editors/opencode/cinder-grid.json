{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "bg_primary":         "#0B0F1A",
    "bg_secondary":       "#070B14",
    "bg_highlight":       "#161D2E",
    "border":             "#1E2840",

    "fg_primary":         "#D8DDE8",
    "fg_dimmed":          "#8A95A8",
    "fg_muted":           "#4E5A6E",
    "fg_gutter":          "#2E3A4E",

    "ember":              "#E8721A",
    "cinder":             "#C85A0E",
    "amber":              "#D4A827",
    "tile_blue":          "#4D8FCC",
    "sky_blue":           "#7BB5D0",
    "moss":               "#5FAD6E",
    "coral":              "#D45C5C",
    "magenta":            "#B87BBB",
    "gold":               "#C8901A",
    "white_hot":          "#F0EAD6",

    "ansi_black":         "#0B0F1A",
    "ansi_red":           "#D45C5C",
    "ansi_green":         "#5FAD6E",
    "ansi_yellow":        "#D4A827",
    "ansi_blue":          "#4D8FCC",
    "ansi_magenta":       "#B87BBB",
    "ansi_cyan":          "#7BB5D0",
    "ansi_white":         "#D8DDE8",
    "ansi_bright_black":  "#2E3A4E",
    "ansi_bright_red":    "#E87070",
    "ansi_bright_green":  "#7DC88C",
    "ansi_bright_yellow": "#E8C048",
    "ansi_bright_blue":   "#6AACDC",
    "ansi_bright_magenta":"#CC96CC",
    "ansi_bright_cyan":   "#96CCDE",
    "ansi_bright_white":  "#F0EAD6"
  },

  "theme": {
    "primary":           { "dark": "ember",       "light": "ember" },
    "secondary":         { "dark": "tile_blue",   "light": "tile_blue" },
    "accent":            { "dark": "sky_blue",    "light": "sky_blue" },
    "error":             { "dark": "coral",       "light": "coral" },
    "warning":           { "dark": "amber",       "light": "amber" },
    "success":           { "dark": "moss",        "light": "moss" },
    "info":              { "dark": "tile_blue",   "light": "tile_blue" },
    "text":              { "dark": "fg_primary",  "light": "fg_primary" },
    "textMuted":         { "dark": "fg_muted",    "light": "fg_muted" },
    "background":        { "dark": "none",        "light": "none" },
    "backgroundPanel":   { "dark": "bg_primary",  "light": "bg_primary" },
    "backgroundElement": { "dark": "bg_highlight","light": "bg_highlight" },
    "border":            { "dark": "border",      "light": "border" },
    "borderActive":      { "dark": "ember",       "light": "ember" },
    "borderSubtle":      { "dark": "border",      "light": "border" },

    "diffAdded":               { "dark": "moss",        "light": "moss" },
    "diffRemoved":             { "dark": "coral",       "light": "coral" },
    "diffContext":             { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHunkHeader":          { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHighlightAdded":      { "dark": "moss",        "light": "moss" },
    "diffHighlightRemoved":    { "dark": "coral",       "light": "coral" },
    "diffAddedBg":             { "dark": "#161D2E",     "light": "#161D2E" },
    "diffRemovedBg":           { "dark": "#161D2E",     "light": "#161D2E" },
    "diffContextBg":           { "dark": "bg_secondary","light": "bg_secondary" },
    "diffLineNumber":          { "dark": "fg_gutter",   "light": "fg_gutter" },
    "diffAddedLineNumberBg":   { "dark": "#161D2E",     "light": "#161D2E" },
    "diffRemovedLineNumberBg": { "dark": "#161D2E",     "light": "#161D2E" },

    "markdownText":            { "dark": "fg_primary",  "light": "fg_primary" },
    "markdownHeading":         { "dark": "amber",       "light": "amber" },
    "markdownLink":            { "dark": "ember",       "light": "ember" },
    "markdownLinkText":        { "dark": "tile_blue",   "light": "tile_blue" },
    "markdownCode":            { "dark": "moss",        "light": "moss" },
    "markdownBlockQuote":      { "dark": "fg_muted",    "light": "fg_muted" },
    "markdownEmph":            { "dark": "magenta",     "light": "magenta" },
    "markdownStrong":          { "dark": "amber",       "light": "amber" },
    "markdownHorizontalRule":  { "dark": "border",      "light": "border" },
    "markdownListItem":        { "dark": "ember",       "light": "ember" },
    "markdownListEnumeration": { "dark": "tile_blue",   "light": "tile_blue" },
    "markdownImage":           { "dark": "ember",       "light": "ember" },
    "markdownImageText":       { "dark": "tile_blue",   "light": "tile_blue" },
    "markdownCodeBlock":       { "dark": "fg_primary",  "light": "fg_primary" },

    "syntaxComment":           { "dark": "fg_muted",    "light": "fg_muted" },
    "syntaxKeyword":           { "dark": "amber",       "light": "amber" },
    "syntaxFunction":          { "dark": "ember",       "light": "ember" },
    "syntaxVariable":          { "dark": "fg_primary",  "light": "fg_primary" },
    "syntaxString":            { "dark": "moss",        "light": "moss" },
    "syntaxNumber":            { "dark": "gold",        "light": "gold" },
    "syntaxType":              { "dark": "tile_blue",   "light": "tile_blue" },
    "syntaxOperator":          { "dark": "fg_dimmed",   "light": "fg_dimmed" },
    "syntaxPunctuation":       { "dark": "fg_dimmed",   "light": "fg_dimmed" }
  }
}
