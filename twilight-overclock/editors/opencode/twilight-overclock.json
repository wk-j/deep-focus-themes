{
  "$schema": "https://opencode.ai/theme.json",

  "defs": {
    "bg_primary":         "#0B1215",
    "bg_secondary":       "#070B0D",
    "bg_highlight":       "#0F1A1E",
    "border":             "#1A2228",

    "fg_primary":         "#E0E0E0",
    "fg_dimmed":          "#8899A6",
    "fg_muted":           "#4A5568",
    "fg_gutter":          "#2D3748",

    "cyan":               "#00F5FF",
    "green":              "#7FB069",
    "amber":              "#FFB347",
    "blue":               "#5B9BD5",
    "lavender":           "#C195D4",
    "coral":              "#FF5F5F",

    "ansi_black":         "#0B1215",
    "ansi_red":           "#FF5F5F",
    "ansi_green":         "#7FB069",
    "ansi_yellow":        "#FFB347",
    "ansi_blue":          "#5B9BD5",
    "ansi_magenta":       "#C195D4",
    "ansi_cyan":          "#00F5FF",
    "ansi_white":         "#E0E0E0",
    "ansi_bright_black":  "#4A5568",
    "ansi_bright_red":    "#FF8080",
    "ansi_bright_green":  "#A3D98E",
    "ansi_bright_yellow": "#FFD080",
    "ansi_bright_blue":   "#80BFFF",
    "ansi_bright_magenta":"#D4B5E8",
    "ansi_bright_cyan":   "#66F9FF",
    "ansi_bright_white":  "#FFFFFF"
  },

  "theme": {
    "primary":           { "dark": "cyan",        "light": "cyan" },
    "secondary":         { "dark": "blue",        "light": "blue" },
    "accent":            { "dark": "lavender",    "light": "lavender" },
    "error":             { "dark": "coral",       "light": "coral" },
    "warning":           { "dark": "amber",       "light": "amber" },
    "success":           { "dark": "green",       "light": "green" },
    "info":              { "dark": "blue",        "light": "blue" },
    "text":              { "dark": "fg_primary",  "light": "fg_primary" },
    "textMuted":         { "dark": "fg_muted",    "light": "fg_muted" },
    "background":        { "dark": "none",        "light": "none" },
    "backgroundPanel":   { "dark": "bg_primary",  "light": "bg_primary" },
    "backgroundElement": { "dark": "bg_highlight","light": "bg_highlight" },
    "border":            { "dark": "border",      "light": "border" },
    "borderActive":      { "dark": "cyan",        "light": "cyan" },
    "borderSubtle":      { "dark": "border",      "light": "border" },

    "diffAdded":               { "dark": "green",       "light": "green" },
    "diffRemoved":             { "dark": "coral",       "light": "coral" },
    "diffContext":             { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHunkHeader":          { "dark": "fg_muted",    "light": "fg_muted" },
    "diffHighlightAdded":      { "dark": "green",       "light": "green" },
    "diffHighlightRemoved":    { "dark": "coral",       "light": "coral" },
    "diffAddedBg":             { "dark": "#0F1A1E",     "light": "#0F1A1E" },
    "diffRemovedBg":           { "dark": "#0F1A1E",     "light": "#0F1A1E" },
    "diffContextBg":           { "dark": "bg_secondary","light": "bg_secondary" },
    "diffLineNumber":          { "dark": "fg_gutter",   "light": "fg_gutter" },
    "diffAddedLineNumberBg":   { "dark": "#0F1A1E",     "light": "#0F1A1E" },
    "diffRemovedLineNumberBg": { "dark": "#0F1A1E",     "light": "#0F1A1E" },

    "markdownText":            { "dark": "fg_primary",  "light": "fg_primary" },
    "markdownHeading":         { "dark": "green",       "light": "green" },
    "markdownLink":            { "dark": "cyan",        "light": "cyan" },
    "markdownLinkText":        { "dark": "blue",        "light": "blue" },
    "markdownCode":            { "dark": "amber",       "light": "amber" },
    "markdownBlockQuote":      { "dark": "fg_muted",    "light": "fg_muted" },
    "markdownEmph":            { "dark": "lavender",    "light": "lavender" },
    "markdownStrong":          { "dark": "green",       "light": "green" },
    "markdownHorizontalRule":  { "dark": "border",      "light": "border" },
    "markdownListItem":        { "dark": "cyan",        "light": "cyan" },
    "markdownListEnumeration": { "dark": "blue",        "light": "blue" },
    "markdownImage":           { "dark": "cyan",        "light": "cyan" },
    "markdownImageText":       { "dark": "blue",        "light": "blue" },
    "markdownCodeBlock":       { "dark": "fg_primary",  "light": "fg_primary" },

    "syntaxComment":           { "dark": "fg_muted",    "light": "fg_muted" },
    "syntaxKeyword":           { "dark": "green",       "light": "green" },
    "syntaxFunction":          { "dark": "cyan",        "light": "cyan" },
    "syntaxVariable":          { "dark": "fg_primary",  "light": "fg_primary" },
    "syntaxString":            { "dark": "amber",       "light": "amber" },
    "syntaxNumber":            { "dark": "amber",       "light": "amber" },
    "syntaxType":              { "dark": "blue",        "light": "blue" },
    "syntaxOperator":          { "dark": "fg_dimmed",   "light": "fg_dimmed" },
    "syntaxPunctuation":       { "dark": "fg_dimmed",   "light": "fg_dimmed" }
  }
}
